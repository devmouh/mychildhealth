# Django Configuration Environment Variables Template
# Copy this file to .env in production and update the values.

# Security settings
DJANGO_SECRET_KEY=django-insecure-og%_8wo!-i9xp939qe)8m@wto+f(u2$3-t2ybt$dbwc0$d*my*
DJANGO_DEBUG=True

# Host configurations (comma-separated list)
